# Database
DATABASE_URL="postgresql://user:password@localhost:5432/emailclock?schema=public"

# Public base URL (used for links in emails)
NEXT_PUBLIC_BASE_URL="https://clock.email"

# SMTP (Postal or any SMTP provider)
SMTP_HOST="localhost"
SMTP_PORT="25"
# SMTP_SECURE="true"
# SMTP_USER=""
# SMTP_PASS=""
EMAIL_FROM="clock.email <noreply@clock.email>"

# Set to "true" to disable outbound email (logs instead)
# EMAIL_DISABLED="true"

# Shared secret for cron endpoints
# CRON_SECRET="your-secret-here"

# Demo mode — shows banner linking to production site
# DEMO_MODE="true"
